# YouTube Data API v3 key.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for your project first.
YOUTUBE_API_KEY=

# ── Feed sources ─────────────────────────────────────────────
# Naver Search API (feed: 네이버뉴스). Free; create an app and enable
# "검색" at https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao REST API key (feed: 다음 web search). Create an app at
# https://developers.kakao.com → REST API key. Used as `Authorization: KakaoAK`.
KAKAO_REST_API_KEY=

# Instagram (feed: 인스타): no token needed — the official account's public
# posts are read via Instagram's logged-out web API (web_profile_info).
# The account is configured as IG_OFFICIAL_USERNAME in src/lib/feed/config.ts.

# /api/feed/warm 운영용 키 (인스타 계정 수동 워밍). 워커에는
# `wrangler secret put FEED_WARM_KEY`로 등록한다.
FEED_WARM_KEY=

# 리스크 알림 웹훅(선택). Discord 호환 JSON({content}) POST. 미설정 시 알림은
# D1 alerts 테이블에만 기록된다.
ALERT_WEBHOOK_URL=
