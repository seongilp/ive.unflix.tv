# YouTube Data API v3 key.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for your project first.
YOUTUBE_API_KEY=

# ── Feed sources ─────────────────────────────────────────────
# Naver Search API (feed: 네이버뉴스). Free; create an app and enable
# "검색" at https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Instagram Graph API token (feed: 인스타, hashtag search #리센느/#RESCENE).
# Token type "Instagram Graph API via Facebook Login" (EAA…). Needs a Business/
# Creator account linked to a Facebook Page. ~30 unique hashtags / 7 days.
INSTAGRAM_GRAPH_TOKEN=
# Optional: the IG Business user id. If unset, it's resolved from /me/accounts.
INSTAGRAM_USER_ID=
